application/storage/logs/*
!application/storage/logs/.gitkeep
application/storage/framework/cache/*
!application/storage/framework/cache/.gitkeep
application/storage/framework/cache/data/*
!application/storage/framework/cache/data/
!application/storage/framework/cache/data/.gitkeep
