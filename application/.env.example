# Application
APP_NAME="Citrus SMS Service"
APP_ENV=local
APP_KEY=base64:GENERATE_A_LOCAL_APP_KEY
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_STAGE=Local
APP_TYPE=local
APP_LOG=single
APP_LOG_LEVEL=debug
TIME_ZONE=UTC
REDIRECT_HTTPS=false
TIMEOUT=30

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=scribble_local
DB_USERNAME=scribble_user
DB_PASSWORD=change_me

# Cache / session / queues
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
BROADCAST_DRIVER=log

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379

# Memcached
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211
MEMCACHED_USERNAME=
MEMCACHED_PASSWORD=
MEMCACHED_PERSISTENT_ID=

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME="${APP_NAME}"
MAILGUN_DOMAIN=
MAILGUN_SECRET=
SES_KEY=
SES_SECRET=
SPARKPOST_SECRET=

# Payments
STRIPE_KEY=
STRIPE_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co
MERCHANT_EMAIL=
GOPAY_ID=
GOPAY_CLIENT_ID=
GOPAY_SECRET=
GOPAY_MODE=sandbox

# Messaging providers
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=
AWS_KEY=
AWS_SECRET=
AWS_REGION=
AWS_BUCKET=

# Broadcasting
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=

# Asterisk / AMI
AMI_HOST=
AMI_PORT=
AMI_USERNAME=
AMI_SECRET=
AMI_DEVICE=
SC_DEVICE=
